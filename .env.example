# Control plane
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://tlg:tlg@postgres:5432/team_llm_gateway?schema=public
DIRECT_URL=postgresql://tlg:tlg@postgres:5432/team_llm_gateway?schema=public
ADMIN_TOKEN=change-me-admin-token
API_KEY_PEPPER=change-me-long-random-pepper
LOG_LEVEL=info

# LiteLLM
LITELLM_MASTER_KEY=sk-admin-change-me
LITELLM_SALT_KEY=change-me-litellm-salt
LITELLM_PORT=4000

# Upstream OpenAI-compatible provider.
# 9router example:
# NINE_ROUTER_BASE_URL=http://9router:20128/v1
NINE_ROUTER_BASE_URL=https://api.9router.local/v1
NINE_ROUTER_API_KEY=replace-with-operator-provided-upstream-key

# Optional Redis
REDIS_URL=redis://redis:6379
