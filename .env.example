# Control plane
NODE_ENV=development
PORT=3000
API_PORT=3000
DATABASE_URL=postgresql://tlg:tlg@postgres:5432/team_llm_gateway?schema=app
DIRECT_URL=postgresql://tlg:tlg@postgres:5432/team_llm_gateway?schema=app
LITELLM_DATABASE_URL=postgresql://tlg:tlg@postgres:5432/team_llm_gateway?schema=litellm
ADMIN_TOKEN=change-me-admin-token
API_KEY_PEPPER=change-me-long-random-pepper
LOG_LEVEL=info

# LiteLLM
LITELLM_MASTER_KEY=sk-admin-change-me
LITELLM_SALT_KEY=change-me-litellm-salt
LITELLM_PORT=4000
LITELLM_PROXY_URL=http://litellm:4000

# Upstream OpenAI-compatible provider.
# 9router example:
# NINE_ROUTER_BASE_URL=http://9router:20128/v1
ROUTER_BASE_URL=http://9router:20128/v1
ROUTER_API_KEY=replace-with-operator-provided-upstream-key
ROUTER_PREMIUM_MODEL=openai/provider-premium-model-id
ROUTER_BALANCED_MODEL=openai/provider-balanced-model-id
ROUTER_FAST_MODEL=openai/provider-fast-model-id
ROUTER_FALLBACK_MODEL=openai/provider-fallback-model-id
ROUTER_AGENT_PREMIUM_MODEL=openai/provider-agent-premium-model-id
ROUTER_AGENT_CHEAP_MODEL=openai/provider-agent-cheap-model-id

# Backward-compatible names; used if ROUTER_* is not set.
NINE_ROUTER_BASE_URL=http://9router:20128/v1
NINE_ROUTER_API_KEY=replace-with-operator-provided-upstream-key

# Optional key defaults applied when creating LiteLLM virtual keys.
DEFAULT_KEY_MAX_BUDGET=
DEFAULT_KEY_BUDGET_DURATION=30d
DEFAULT_KEY_TPM_LIMIT=
DEFAULT_KEY_RPM_LIMIT=

# Optional Redis
REDIS_URL=redis://redis:6379
